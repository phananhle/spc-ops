# Anthropic API key for the Socratic tutor.
# Copy this file to .env.local and fill in a real key. .env.local is gitignored.
#
# DEV-ONLY: this key is exposed to the browser via Vite's import.meta.env.
# Do NOT use this build for public deploys. A serverless proxy is required for production.
VITE_ANTHROPIC_API_KEY=sk-ant-...
